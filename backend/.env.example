# ── Gege Mould Backend ──
# Copy this file to .env and fill in your real values.
# Never commit .env to version control.

# ── Server ──
PORT=3000
NODE_ENV=production

# ── Admin Panel ──
# Password required to access the admin dashboard at /admin.html
# Change this to a strong, unique password before deploying
ADMIN_PASSWORD=change-me-to-a-strong-password

# ── Email (SMTP via Nodemailer) ──
# Alibaba Cloud Enterprise Email (企业邮箱) — smtp.qiye.aliyun.com
#
# PREREQUISITES (do these in the Alibaba Cloud admin console FIRST):
#   1. Log into your Alibaba Cloud Enterprise Email admin console
#      (https://qiye.aliyun.com or https://mail.aliyun.com)
#   2. Navigate to: Settings → Security Settings → SMTP Service
#   3. Ensure "Enable SMTP service" is ON for the
#      sales@automotivemouldfactory.com mailbox
#   4. If 2FA is enabled on this mailbox, generate an "App Password"
#      (客户端密码 / client password) — you MUST use the app password as
#      SMTP_PASS below, NOT your regular web-login password
#   5. If 2FA is NOT enabled, use the regular mailbox password as SMTP_PASS
#
# Port guide:
#   - 465 (SSL/TLS) — recommended primary; this is the standard Alibaba
#     Cloud Enterprise Email SMTP port
#   - 587 (STARTTLS) — alternate if 465 is blocked by your network/firewall
#   - 25  — legacy; usually blocked by ISPs for outbound mail
#
SMTP_HOST=smtp.qiye.aliyun.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=sales@automotivemouldfactory.com
SMTP_PASS=your-mailbox-password-or-app-password-here
SMTP_FROM="Gege Mould" <sales@automotivemouldfactory.com>

# Recipient email for all form notifications (quote, RFQ, quick message)
QUOTE_RECIPIENT=sales@automotivemouldfactory.com

# ── Database ──
# Path to SQLite database file (relative to server.js, or absolute)
DB_PATH=./data/submissions.db

# ── Rate Limiting ──
# Max submissions per IP per 15-minute window
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_MS=900000

# ── CORS ──
# Comma-separated list of allowed origins for the API
ALLOWED_ORIGINS=https://gegemould.com,https://www.gegemould.com,http://localhost:3000
