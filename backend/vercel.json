{
  "version": 2,
  "buildCommand": "echo 'Static site + Express API — no build step'",
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/api/quote", "destination": "/backend/server.js" },
    { "source": "/api/rfq", "destination": "/backend/server.js" },
    { "source": "/api/widget-interaction", "destination": "/backend/server.js" },
    { "source": "/api/health", "destination": "/backend/server.js" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains; preload" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "redirects": [
    { "source": "/capabilities", "destination": "/capabilities.html", "permanent": true },
    { "source": "/about", "destination": "/about.html", "permanent": true },
    { "source": "/quality", "destination": "/quality.html", "permanent": true },
    { "source": "/contact", "destination": "/contact.html", "permanent": true },
    { "source": "/news", "destination": "/news.html", "permanent": true },
    { "source": "/industries", "destination": "/industries.html", "permanent": true },
    { "source": "/faqs", "destination": "/faqs.html", "permanent": true }
  ]
}
